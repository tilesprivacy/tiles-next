{
  "name": "tiles-release-serve",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "upload:latest-pkg": "node ./scripts/trigger-upload.mjs latest-pkg",
    "upload:file": "node ./scripts/trigger-upload.mjs upload-file",
    "secret:github-token": "wrangler secret put GITHUB_TOKEN",
    "secret:sync-token": "wrangler secret put SYNC_TRIGGER_TOKEN"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "wrangler": "^4.46.0"
  }
}
